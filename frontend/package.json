{
  "name": "chatapp-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:android": "npm run build && npx cap sync android",
    "build:ios": "tsc -b && vite build --mode android && npx cap sync ios",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:apk": "cd android && JAVA_HOME=${JAVA_HOME:-$(/usr/libexec/java_home -v 21 2>/dev/null || echo \"$JAVA_HOME\")} ./gradlew assembleDebug && mkdir -p ../public/downloads && cp app/build/outputs/apk/debug/app-debug.apk ../public/downloads/pandamind.apk",
    "ios:open": "npx cap open ios",
    "ios:run": "npx cap run ios",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "livekit-client": "^2.19.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
