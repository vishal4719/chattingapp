# Copy to repo root as .env before: docker compose up --build
#
# IMPORTANT: VITE_* URLs must be what the BROWSER uses (public host/IP + port),
# not Docker internal service names.

# --- Ports exposed on your machine ---
FRONTEND_PORT=8080
BACKEND_PORT=3000

# --- Public URLs (browser → backend) ---
# Single VPS example (replace YOUR_SERVER_IP):
FRONTEND_URL=http://YOUR_SERVER_IP:8080
VITE_API_URL=http://YOUR_SERVER_IP:3000
VITE_WS_URL=http://YOUR_SERVER_IP:3000

# Domain + reverse-proxy example:
# FRONTEND_URL=https://chat.example.com
# VITE_API_URL=https://api.example.com
# VITE_WS_URL=https://api.example.com

# --- Backend secrets ---
DATABASE_URL=postgresql://user:pass@host:5432/chatapp?sslmode=require
JWT_SECRET=change-me-to-a-long-random-string

# S3 (file uploads)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=
S3_PREFIX=test-chatbot
MAX_UPLOAD_BYTES=26214400

# Seed admin (only when RUN_SEED=true)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# First deploy: apply schema + seed default admin
RUN_MIGRATIONS=true
RUN_SEED=true

# Optional local Postgres (docker compose --profile local-db up)
# POSTGRES_USER=chatapp
# POSTGRES_PASSWORD=chatapp
# POSTGRES_DB=chatapp
# DATABASE_URL=postgresql://chatapp:chatapp@postgres:5432/chatapp
