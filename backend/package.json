    "next": "^15.3.3",
    "prisma": "^6.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "tsx": "^4.19.4",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/jsonwebtoken": "^9.0.9",
