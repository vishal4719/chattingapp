# Required — frontend origin (must match where the React app runs)
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://chatapp.vishaltech.in

# Public backend URL (used for invite links, push notification URLs)
# API_PUBLIC_URL=https://api.vishaltech.in

# Optional — extra CORS origins (comma-separated), e.g. Capacitor Android APK
# EXTRA_CORS_ORIGINS=https://localhost,capacitor://localhost

# Required
DATABASE_URL=
JWT_SECRET=
PORT=3000

# Seed admin (run: npx prisma db seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Required for file uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=
S3_PREFIX=test-chatbot
MAX_UPLOAD_BYTES=26214400

# LiveKit (video/audio calls)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# Firebase Cloud Messaging (free) — create project at console.firebase.google.com
# Download service account JSON or set the three vars below.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
